<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>藥到病除老友記 - 智能控制面板</title>
    <!-- 引入 EmailJS SDK 用於靜態網頁發送電子郵件 -->
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
    <style>
        :root {
            --primary-bg: #f5f9fc;
            --card-blue: #e8f4fd;
            --card-green: #eafaf1;
            --card-orange: #fef5e7;
            --card-pink: #fdeef4;
            --card-purple: #f3f0fc;
            --text-dark: #2c3e50;
            --success-color: #2ecc71;
            --danger-color: #e74c3c;
            --accent-yellow: #f1c40f;
            --primary-blue: #3498db;
        }

        body {
            font-family: 'PingFang HK', 'Microsoft JhengHei', sans-serif;
            background-color: var(--primary-bg);
            color: var(--text-dark);
            margin: 0;
            padding: 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* 頂部超大時鐘與連線面板 */
        .header-section {
            width: 100%;
            max-width: 600px;
            background: white;
            border-radius: 24px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.05);
            padding: 20px;
            text-align: center;
            margin-bottom: 20px;
            box-sizing: border-box;
            border: 4px solid #d4e6f1;
        }

        .system-clock {
            font-size: 3.5rem;
            font-weight: bold;
            color: #2980b9;
            margin: 5px 0;
            text-shadow: 1px 1px 0px white, 2px 2px 0px rgba(0,0,0,0.05);
        }

        .clock-label {
            font-size: 1.2rem;
            color: #7f8c8d;
            letter-spacing: 2px;
        }

        /* 藍牙狀態卡片 */
        .bluetooth-status-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #f8f9fa;
            padding: 15px 20px;
            border-radius: 16px;
            margin-top: 15px;
            border: 2px dashed #bdc3c7;
        }

        .status-badge {
            font-size: 1.2rem;
            font-weight: bold;
            padding: 8px 16px;
            border-radius: 12px;
        }

        .status-disconnected {
            background-color: #fadbd8;
            color: var(--danger-color);
        }

        .status-connected {
            background-color: #d4efdf;
            color: var(--success-color);
        }

        /* 藥盒卡片區域 */
        .box-container {
            width: 100%;
            max-width: 600px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            box-sizing: border-box;
            margin-bottom: 120px; /* 為底部預留空間 */
        }

        .med-card {
            border-radius: 28px;
            padding: 20px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.03);
            border: 3px solid transparent;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .med-card.disabled {
            opacity: 0.55;
            background: #eceff1 !important;
            border-color: #cfd8dc !important;
        }

        /* 卡片的可愛亮麗主題顏色 */
        .card-1 { background-color: var(--card-blue); border-color: #aed6f1; }
        .card-2 { background-color: var(--card-green); border-color: #abebc6; }
        .card-3 { background-color: var(--card-orange); border-color: #fad7a0; }
        .card-4 { background-color: var(--card-pink); border-color: #f5b7b1; }
        .card-iot { background-color: var(--card-purple); border-color: #d7bde2; }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .card-title {
            font-size: 1.8rem;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* 可愛滑動開關 */
        .switch {
            position: relative;
            display: inline-block;
            width: 68px;
            height: 38px;
        }

        .switch input { opacity: 0; width: 0; height: 0; }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 34px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 30px; width: 30px;
            left: 4px; bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked + .slider { background-color: var(--success-color); }
        input:checked + .slider:before { transform: translateX(30px); }

        /* 資訊面板：大字體長者設計 */
        .med-info {
            background: rgba(255, 255, 255, 0.7);
            border-radius: 18px;
            padding: 15px;
            margin-bottom: 15px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 8px 0;
            flex-wrap: wrap;
            gap: 10px;
        }

        .info-label {
            font-size: 1.2rem;
            color: #566573;
        }

        .info-value {
            font-size: 1.6rem;
            font-weight: bold;
            color: var(--text-dark);
        }

        .time-picker-custom {
            font-size: 1.5rem;
            font-weight: bold;
            padding: 5px 10px;
            border-radius: 10px;
            border: 2px solid #bdc3c7;
            background-color: white;
            color: var(--text-dark);
        }

        /* 倒數計時器 */
        .countdown-timer {
            font-size: 1.1rem;
            color: #7f8c8d;
            background: rgba(255, 255, 255, 0.5);
            padding: 5px 12px;
            border-radius: 20px;
            display: inline-block;
            margin-top: 5px;
            font-weight: bold;
        }

        /* 錄音控制面板 */
        .recorder-box {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 15px;
            background: rgba(255,255,255,0.9);
            padding: 12px;
            border-radius: 16px;
            align-items: center;
            justify-content: space-between;
        }

        /* 大按鈕設計 */
        button {
            font-size: 1.2rem;
            font-weight: bold;
            padding: 12px 20px;
            border: none;
            border-radius: 16px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: transform 0.1s, opacity 0.2s;
        }

        button:active { transform: scale(0.95); }
        button:disabled { opacity: 0.5; cursor: not-allowed; }

        .btn-primary { background-color: #3498db; color: white; }
        .btn-success { background-color: var(--success-color); color: white; }
        .btn-danger { background-color: var(--danger-color); color: white; }
        .btn-accent { background-color: var(--accent-yellow); color: #2c3e50; }
        .btn-edit { background-color: #95a5a6; color: white; padding: 6px 12px; font-size: 0.95rem; border-radius: 10px; }

        /* 編輯彈窗/輸入控制 */
        .edit-input {
            font-size: 1.3rem;
            padding: 10px 15px;
            border-radius: 12px;
            border: 2px solid #3498db;
            width: 100%;
            max-width: 300px;
            font-weight: bold;
            box-sizing: border-box;
        }

        /* 提示訊息橫條 */
        .toast-msg {
            background-color: #2c3e50;
            color: white;
            padding: 12px 24px;
            border-radius: 50px;
            position: fixed;
            bottom: 120px;
            font-weight: bold;
            display: none;
            z-index: 10000;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            animation: fadeInUp 0.3s ease;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* 吃藥成功超大喜慶稱讚彈窗 */
        .praise-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .praise-card {
            background: radial-gradient(circle, #fffdf0 60%, #fef5e7 100%);
            width: 90%;
            max-width: 500px;
            padding: 40px 20px;
            border-radius: 36px;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            border: 8px solid var(--accent-yellow);
            animation: bounceIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .praise-emoji {
            font-size: 8rem;
            margin: 10px 0;
            display: block;
            animation: pulse 1.5s infinite;
        }

        .praise-title {
            font-size: 2.8rem;
            color: #d35400;
            margin: 10px 0;
            font-weight: 900;
        }

        .praise-text {
            font-size: 1.8rem;
            color: #2c3e50;
            line-height: 1.5;
            margin-bottom: 25px;
            font-weight: bold;
        }

        @keyframes bounceIn {
            0% { transform: scale(0.3); opacity: 0; }
            50% { transform: scale(1.05); }
            70% { transform: scale(0.9); }
            100% { transform: scale(1); opacity: 1; }
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }

        /* 錄音中動畫效果 */
        .recording-status {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            color: var(--danger-color);
            font-weight: bold;
            font-size: 1.1rem;
            animation: blink 1s infinite;
        }

        .dot {
            width: 10px; height: 10px;
            background-color: var(--danger-color);
            border-radius: 50%;
        }

        @keyframes blink {
            50% { opacity: 0.3; }
        }

        /* 手機底部固定按鈕 */
        .bottom-nav {
            position: fixed;
            bottom: 0; left: 0; width: 100%;
            background: white;
            box-shadow: 0 -4px 15px rgba(0,0,0,0.08);
            display: flex;
            justify-content: center;
            padding: 15px;
            box-sizing: border-box;
            z-index: 100;
        }
    </style>
</head>
<body>


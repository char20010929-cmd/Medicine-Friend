                <div class="countdown-timer" id="countdown-2">計算時間中...</div>
            </div>
            
            <div class="recorder-box">
                <span class="info-label" style="font-weight: bold;">🗣️ 錄音提醒：</span>
                <div id="record-ui-2">
                    <button class="btn-danger" id="rec-btn-2" onclick="startRecording(2)">🔴 錄音</button>
